# OpenGradient
OPENGRADIENT_ENABLED=true
OG_PRIVATE_KEY=your_private_key_here
OPENGRADIENT_MODEL=anthropic/claude-sonnet-4-6
OPENGRADIENT_SETTLEMENT_MODE=BATCH_HASHED
OPENGRADIENT_APPROVAL_AMOUNT=5.0
ALLOW_MOCK_OPENGRADIENT=true

# CoinGecko
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Server
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=sqlite+aiosqlite:///./og_markets.db
